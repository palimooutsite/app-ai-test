generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  OWNER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

enum ConnectionProvider {
  BANK_API
  SHOPEE
  TOKOPEDIA
}

model Company {
  id           String                @id @default(uuid())
  name         String
  taxId        String?               @unique
  baseCurrency String                @default("IDR")
  users        User[]
  accounts     Account[]
  entries      JournalEntry[]
  bankTxns     BankTransaction[]
  connections  ExternalConnection[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         UserRole
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Account {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code          String
  name          String
  type          AccountType
  parentId      String?
  parent        Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]   @relation("AccountHierarchy")
  isActive      Boolean     @default(true)
  journalLines  JournalLine[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type])
}

model JournalEntry {
  id           String        @id @default(uuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referenceNo  String
  description  String
  entryDate    DateTime
  status       JournalStatus @default(POSTED)
  lines        JournalLine[]
  createdById  String
  createdBy    User          @relation(fields: [createdById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([companyId, referenceNo])
  @@index([companyId, entryDate])
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @db.Decimal(18, 2)
  credit         Decimal      @db.Decimal(18, 2)
  memo           String?

  @@index([accountId])
}

model ExternalConnection {
  id            String             @id @default(uuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider      ConnectionProvider
  externalOrgId String?
  accessToken   String
  refreshToken  String?
  metadata      Json?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([companyId, provider])
}

model BankTransaction {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  externalId    String
  amount        Decimal   @db.Decimal(18, 2)
  txnDate       DateTime
  description   String
  reference     String?
  accountNumber String?
  createdAt     DateTime  @default(now())

  @@unique([companyId, externalId])
  @@index([companyId, txnDate])
}
